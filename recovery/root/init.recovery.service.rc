# =============================================================================  
# init.recovery.service.rc  
# HAL service definitions for FBE decryption in OrangeFox recovery  
#  
# Decryption chain:  
#   kernel modules (loaded in init.recovery.qcom.rc)  
#     → qseecomd (TEE daemon, talks to TrustZone via /dev/qseecom)  
#       → property: vendor.sys.listeners.registered=true  
#         → OneKeyMint (Rust AIDL KeyMint, key unwrapping for wrappedkey_v0)  
#         → Gatekeeper (Rust AIDL Gatekeeper, PIN/password verification)  
#  
# Source RC files (100% verified from device):  
#   /vendor/etc/init/qseecomd.rc  
#   /vendor/etc/init/android.hardware.security.onekeymint-service-qti.rc  
#   /vendor/etc/init/android.hardware.gatekeeper-service-qti.rc  
#  
# Critical notes:  
#   - /dev/keystore does NOT exist on this device (Android 16 OneKeyMint)  
#   - OneKeyMint communicates via smcinvoke (/dev/qseecom), not /dev/keystore  
#   - qseecomd runs as root:root,drmrpc with socket notify-topology  
# =============================================================================  
  
# ===========================================================
# Service: qseecomd (Qualcomm Secure Execution Environment daemon)
#
# Verified from: cat /vendor/etc/init/qseecomd.rc
# Original content:
#   service vendor.qseecomd /vendor/bin/qseecomd
#       socket notify-topology stream 660 system drmrpc
#       class core
#       user root
#       group root drmrpc
#
# Verified runtime:
#   PID 1090, user=system(mapped from root in init), parent=1
#   cmdline: /vendor/bin/qseecomd (no extra args)
#   Completion: vendor.sys.listeners.registered=true
#
# Socket: notify-topology (stream, 660, system:drmrpc)
#   Used by TEE listener infrastructure for HAL registration notifications.
#
# Recovery adaptation:
#   - class changed to hal (recovery init does not use "core" trigger)
#   - user/group kept as root/root,drmrpc per vendor original
#   - disabled: started explicitly from init.recovery.qcom.rc "on boot"
#   - seclabel: u:r:recovery:s0 (recovery permissive context)
#
# Library dependencies (verified from /proc/1090/maps, 25 libraries):
#   /vendor/lib64/libQSEEComAPI.so
#   /vendor/lib64/libGPreqcancel.so
#   /vendor/lib64/libGPreqcancel_svc.so
#   /vendor/lib64/libdiag.so
#   /vendor/lib64/libdmabufheap.so
#   /vendor/lib64/libdrm.so
#   /vendor/lib64/libdrmfs.so
#   /vendor/lib64/libdrmtime.so
#   /vendor/lib64/libgpt.so
#   /vendor/lib64/libminkdescriptor.so
#   /vendor/lib64/libops.so
#   /vendor/lib64/libqcbor.so
#   /vendor/lib64/libqisl.so
#   /vendor/lib64/librpmb.so
#   /vendor/lib64/libseclog.so
#   /vendor/lib64/libspl.so
#   /vendor/lib64/libssd.so
#   /vendor/lib64/libtime_genoff.so
#   /vendor/lib64/libutils.so
#   /vendor/lib64/libxml2.so
#   /vendor/lib64/vendor.qti.hardware.display.config-V7-ndk.so
#   /system/lib64/libbinder_ndk.so
#   /system/lib64/libcutils.so
#   /system/lib64/libbase.so
# ===========================================================
service vendor.qseecomd /vendor/bin/qseecomd
    class hal
    user root
    group root drmrpc
    socket notify-topology stream 660 system drmrpc
    disabled
    seclabel u:r:recovery:s0

# ===========================================================
# Service: OneKeyMint (Qualcomm AIDL KeyMint 3.0, Rust binary)
#
# Verified from: cat /vendor/etc/init/android.hardware.security.onekeymint-service-qti.rc
# Original content:
#   on init
#       start vendor.keymint
#   service vendor.keymint /vendor/bin/hw/android.hardware.security.onekeymint-service-qti
#       class early_hal
#       user system
#       group system drmrpc
#
# Function: Unwraps FBE per-file keys via hardware-bound master key in TEE.
#   fstab encryption: wrappedkey_v0 → KeyMint unwrapKey() → ICE inline crypto
#
# Library dependencies (verified from /proc/1175/maps):
#   /vendor/lib64/libminkdescriptor.so
#   /vendor/lib64/libbase.so
#   /vendor/lib64/libc++.so
#   /vendor/lib64/libcutils.so
#   /vendor/lib64/libqcbor.so
#   /vendor/lib64/libutils.so
#   /vendor/lib64/libbinder_ndk.so
#   /system/lib64/liblog.so
# ===========================================================
service vendor.keymint /vendor/bin/hw/android.hardware.security.onekeymint-service-qti
    class hal
    user system
    group system drmrpc
    disabled
    seclabel u:r:recovery:s0

# ===========================================================
# Service: Gatekeeper (Qualcomm AIDL Gatekeeper, Rust binary)
#
# Verified from: cat /vendor/etc/init/android.hardware.gatekeeper-service-qti.rc
# Original content:
#   service vendor.gatekeeper_default /vendor/bin/hw/android.hardware.gatekeeper-rust-service-qti
#       class early_hal
#       user system
#       group system
#   on property:vendor.gatekeeper.is_security_level_spu=0
#       enable vendor.gatekeeper_default
#
# Function: Verifies user credential (PIN/password/pattern) and produces
#   auth tokens consumed by KeyMint for key access control.
#
# Library dependencies (verified from /proc/1268/maps):
#   /vendor/lib64/libminkdescriptor.so
#   /system/lib64/libbinder_ndk.so
#   /system/lib64/liblog.so
# ===========================================================
service vendor.gatekeeper_default /vendor/bin/hw/android.hardware.gatekeeper-rust-service-qti
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# ===========================================================
# Startup triggers
# ===========================================================

# qseecomd is started from init.recovery.qcom.rc "on boot" via:
#   start vendor.qseecomd

# When qseecomd completes TEE listener registration, it sets:
#   vendor.sys.listeners.registered=true (verified via getprop)
# At that point, start the crypto HALs:
on property:vendor.sys.listeners.registered=true
    start vendor.keymint
    start vendor.gatekeeper_default
