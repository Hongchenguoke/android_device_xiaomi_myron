on init
    start vendor.qseecomd

service vendor.qseecomd /vendor/bin/qseecomd
    class core
    user system
    group system drmrpc
    # 真机验证：定义了 socket，Recovery 中保留以确保 TEE 通信句柄初始化
    socket qseecomd stream 0660 system drmrpc
    seclabel u:r:recovery:s0
    disabled