# REMOVED: on init start vendor.keymint
# Recovery init.recovery.qcom.rc handles qseecomd readiness first

service vendor.keymint /vendor/bin/hw/android.hardware.security.onekeymint-service-qti
    class early_hal
    user system
    group system drmrpc
    seclabel u:r:recovery:s0
    # 注意：真机验证此服务 PID 持续存活，严禁 oneshot
    disabled