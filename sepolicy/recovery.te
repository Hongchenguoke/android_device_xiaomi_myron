# =============================================================================
# recovery.te
# SELinux policy for OrangeFox recovery — Xiaomi Myron
# Platform: Canoe (Snapdragon 8 Elite) / Android 16
#
# Recovery runs as PERMISSIVE domain (TWRP base)。
# 以下 allow rules 用于消除 AVC log noise 并确保编译通过。
# =============================================================================

# ===========================================================
# Type Declarations — 仅声明设备专属类型
#
# AOSP base 已定义: tee_device, block_device, vendor_file,
#   sysfs, system_file, rootfs, configfs, functionfs,
#   metadata_file, proc, binder_device,
#   hwbinder_device, vndbinder_device, input_device,
#   graphics_device, tmpfs, devpts, log_device
#
# 不要重复声明以上 AOSP 类型。
# ===========================================================

# /dev/spcom — Qualcomm Secure Processor 通信节点
type spcom_device, dev_type;

# /dev/dma_heap/qcom,qseecom* — TEE 内存分配 DMA heap
type qseecom_dma_heap_device, dev_type;

# persist 分区挂载点标记
type persist_file, file_type;

# 固件文件类型（/vendor/firmware_mnt/image/ - TEE 固件）
type firmware_file, file_type;

# Keystore 数据文件类型（加密元数据存储）
type keystore_data_file, file_type;

# 将 recovery 域设为 permissive
# 若 AOSP base policy 已声明，此语句重复但无害（permissive 允许累加）
permissive recovery;

# ===========================================================
# Allow Rules — 自定义类型 + AOSP 类型混合
# ===========================================================

# TEE 设备节点访问（spcom + DMA heap）
allow recovery spcom_device:chr_file { open read write ioctl getattr };
allow recovery qseecom_dma_heap_device:chr_file { open read write ioctl getattr };

# 执行 vendor 二进制文件（qseecomd / HAL / 库）
# execute_no_trans: 允许执行 vendor_file 且无需 domain transition
allow recovery vendor_file:file { read open execute execute_no_trans map };
allow recovery vendor_file:dir { search read open };

# 执行 system 二进制文件
allow recovery system_file:file { read open execute map };
allow recovery system_file:dir { search read open };

# 块设备（挂载分区、刷写 raw 镜像）
allow recovery block_device:dir search;
allow recovery block_device:blk_file { read write open ioctl };

# sysfs（背光、LED、温度、电池、USB）
allow recovery sysfs:dir { search read open };
allow recovery sysfs:file { read open write };

# tmpfs（运行时创建文件、目录）
allow recovery tmpfs:dir { write add_name create search };
allow recovery tmpfs:file { create write open read };

# binder / hwbinder / vndbinder（HAL 向 hwservicemanager 注册必需）
allow recovery binder_device:chr_file { read write ioctl open };
allow recovery hwbinder_device:chr_file { read write ioctl open };
allow recovery vndbinder_device:chr_file { read write ioctl open };

# property 设置（setprop 命令）
allow recovery default_prop:property_service set;
allow recovery vendor_default_prop:property_service set;

# service_manager / hwservice_manager（HAL 注册）
allow recovery default_android_service:service_manager { find add };
allow recovery default_android_hwservice:hwservice_manager { find add };

# firmware 目录（TEE 可能读取 /vendor/firmware_mnt/image/）
allow recovery firmware_file:dir { search read };
allow recovery firmware_file:file { read open };

# keystore / gatekeeper 数据目录
allow recovery keystore_data_file:dir { search read write add_name };
allow recovery keystore_data_file:file { create read write open };

# capability（recovery 运行所需特权）
allow recovery self:capability { sys_admin mknod chown dac_override dac_read_search fowner fsetid setgid setuid net_admin net_raw sys_module };

# input 设备（触摸屏 /dev/input/event*）
allow recovery input_device:dir search;
allow recovery input_device:chr_file { read write open ioctl };
